SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# External PostgreSQL (the database runs OUTSIDE Docker).
#   - Docker + Postgres on the SAME host:  @host.docker.internal:5432
#   - Docker + managed/remote Postgres:    @db.example.com:5432
#   - Bare-metal `make dev` (no Docker):   @localhost:5432
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/tgpanel

# DEBUG=True allows login over plain HTTP (cookies are not marked Secure) — keep
# it True for local testing. Set DEBUG=False in production (HTTPS); that also
# makes a real SECRET_KEY mandatory.
DEBUG=True

# Public HTTPS base URL for Telegram webhooks. Leave empty for local HTTP
# testing (no incoming messages); set to https://yourdomain.com in production.
WEBHOOK_BASE_URL=

# Origin allowed by CORS: http://localhost for local, https://yourdomain.com in prod.
FRONTEND_URL=http://localhost

# Auto-create superuser on first startup (skipped if a superuser already exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

ADMIN_LOGIN_PATH=/manage/login
